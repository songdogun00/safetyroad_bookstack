server {
    listen 80;
    server_name _;

    root /var/www/bookstack/public;
    index index.php;

    client_max_body_size 100M;

    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    location ~ \.php$ {
        include fastcgi.conf;
        fastcgi_pass bookstack:9000;
    }
}
