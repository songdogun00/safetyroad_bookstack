# 템플릿입니다. 복사해서 실제 값으로 채운 .env 를 만드세요:
#   cp .env.example .env
# .env 에는 비밀이 들어가므로 절대 커밋하지 마세요 (.gitignore 에 등록됨).

# 데이터를 둘 호스트의 외부 절대 경로 (Oracle 예시의 /opt/oracle 자리).
# 실제 데이터는 ${DATA_ROOT}/config (BookStack), ${DATA_ROOT}/db (MariaDB) 에 저장됩니다.
DATA_ROOT=/opt/bookstack

# 접속 주소 (호스트 IP/도메인 + 포트 8000). 뒤에 슬래시 붙이지 마세요.
# 로컬 실험이면 http://localhost:8000 도 가능합니다.
APP_URL=http://localhost:8000

# 아래 명령으로 한 번 생성한 뒤 base64:... 값을 그대로 넣으세요:
#   docker run -it --rm --entrypoint /bin/bash lscr.io/linuxserver/bookstack:latest appkey
APP_KEY= g5HnB9PDuUK6kMXDze/zgx4qewqJ6tM6RAdM4Oy04LI=

# DB 접속 정보 (BookStack 전용 MariaDB)
DB_DATABASE=bookstackapp
DB_USERNAME=bookstack
DB_PASSWORD=asdf
DB_ROOT_PASSWORD=asdf

# 호스트 운영 계정의 uid/gid (`id` 로 확인). 볼륨 권한 문제 방지용.
PUID=1000
PGID=1000
